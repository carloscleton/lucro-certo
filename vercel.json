{
    "version": 2,
    "functions": {
        "server/index.ts": {
            "runtime": "@vercel/node"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/server/index.ts"
        },
        {
            "source": "/((?!api/|assets/|.*\\..*).*)",
            "destination": "/index.html"
        }
    ]
}